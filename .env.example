# ---- Live AIS (server-side ONLY; never expose to the browser) ----
AISSTREAM_KEY=

# Optional bbox override "minLat,minLon,maxLat,maxLon"; else derived from registry.
# BBOX_OVERRIDE=-35.0,-78.0,-8.0,-70.0

# ---- Enrichment jobs ----
COMTRADE_KEY=
# FLOWS_PERIOD=202605   # YYYYMM for the flows job

# ---- Detection tuning (optional; sensible defaults in collector/config.py) ----
# SOG_STOPPED_KN=1.0
# MIN_ARRIVAL_MIN=20
# STATE_WRITE_SEC=45
# Z_ALERT=2.0
# REQUIRE_VERIFIED_POLYGON=1   # set 0 to arm alerts on unverified placeholder polygons

# ---- Email alerts (optional; logs-only if unset) ----
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
ALERT_TO=
